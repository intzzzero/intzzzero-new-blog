---
import '../styles/aonote.css';
import '../styles/terminal-accent.css';
import { site } from '../site.config';
import { siteHref } from '../utils/paths';
import { t, type Locale } from '../i18n';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  pageId?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  /** Show visually-hidden h1 in page-header (home, archive, about). */
  hiddenPageTitle?: boolean;
  /** ISO date for article Open Graph (post pages). */
  articlePublishedTime?: string;
  /** ISO date the article was last modified (defaults to published). */
  articleModifiedTime?: string;
  /** JSON-LD object to emit in <head> (structured data for SEO/GEO). */
  jsonLd?: unknown;
  /** Absolute URL of a raw Markdown alternate (post pages) for AI crawlers. */
  markdownUrl?: string;
  /** BCP-47 language for <html lang> / og:locale. Defaults to the site language. */
  htmlLang?: string;
}

const locale = site.language as Locale;
const i18n = t(locale);

const {
  title,
  description = site.description,
  pageId = 'page',
  canonicalUrl,
  noindex = false,
  hiddenPageTitle = false,
  articlePublishedTime,
  articleModifiedTime,
  jsonLd,
  markdownUrl,
  htmlLang = i18n.htmlLang,
} = Astro.props;

const ogLocale = htmlLang === 'en' ? 'en_US' : 'ko_KR';

// Google Analytics 4. Only load in production builds with a configured tag, so
// `npm run dev` does not send pageviews to GA. See src/site.config.ts.
const gaId =
  import.meta.env.PROD && site.analytics.enabled ? site.analytics.measurementId : null;
const homeHref = siteHref('/');
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();

function normalizePath(pathname: string): string {
  if (!pathname || pathname === '/') return siteHref('/');
  return pathname.endsWith('/') ? pathname : `${pathname}/`;
}

/** Match upstream: prefer `pageId`, then normalized pathname (trailing slash safe). */
function navCurrent(path: string) {
  const normalized = path.endsWith('/') ? path : `${path}/`;
  const href = siteHref(normalized);
  if (path === '/') return pageId === 'index';
  if (normalized === '/about/') return pageId === 'about';
  if (normalized === '/archive/') return pageId === 'archive';
  if (normalized === '/tags/') return pageId === 'tags';
  if (normalized === '/categories/') return pageId === 'categories' || pageId === 'category';
  return normalizePath(currentPath) === href;
}
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={siteHref('/favicon.svg')} type="image/svg+xml" />
    <link rel="preload" href={siteHref('/fonts/pacifico-latin-400.woff2')} as="font" type="font/woff2" crossorigin />
    <title>{title} - {site.title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121212" media="(prefers-color-scheme: dark)" />
    {noindex ? (
      <meta name="robots" content="noindex, follow" />
    ) : (
      canonicalUrl && <link rel="canonical" href={canonicalUrl} />
    )}
    <meta property="og:type" content={pageId === 'post' ? 'article' : 'website'} />
    <meta property="og:title" content={`${title} - ${site.title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={ogLocale} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {articlePublishedTime && (
      <>
        <meta property="article:published_time" content={articlePublishedTime} />
        <meta property="article:modified_time" content={articleModifiedTime ?? articlePublishedTime} />
        <meta property="article:author" content={site.author} />
      </>
    )}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} - ${site.title}`} />
    <meta name="twitter:description" content={description} />
    <meta name="naver-site-verification" content="786561c6e1f9978efa5241c768c3a05f00b6a5a4" />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS Feed`} href={siteHref('/rss.xml')} />
    <link rel="alternate" type="application/atom+xml" title={`${site.title} Atom Feed`} href={siteHref('/atom.xml')} />
    {markdownUrl && <link rel="alternate" type="text/markdown" href={markdownUrl} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />}
    {site.adsense.enabled && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${site.adsense.client}`}
        crossorigin="anonymous"
      ></script>
    )}
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script
          is:inline
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`}
        ></script>
      </>
    )}
  </head>
  <body class={`page-${pageId}`}>
    <a href="#main-content" class="skip-link">{i18n.skipToContent}</a>

    <header>
      <div class="header-inner">
        <a href={homeHref} class="site-title">{site.title}</a>
        <nav class="desktop-nav" aria-label={i18n.mainNavigation}>
          <a href={siteHref('/categories/')} aria-current={navCurrent('/categories') ? 'page' : undefined}>{i18n.navCategories}</a>
          <a href={siteHref('/archive/')} aria-current={navCurrent('/archive') ? 'page' : undefined}>{i18n.navArchive}</a>
          <a href={siteHref('/tags/')} aria-current={navCurrent('/tags') ? 'page' : undefined}>{i18n.navTags}</a>
        </nav>
        <details class="mobile-nav-menu">
          <summary aria-label={i18n.navMenu}>
            <span class="visually-hidden">{i18n.navMenu}</span>
            <span class="hamburger-icon" aria-hidden="true"></span>
          </summary>
          <nav class="mobile-nav-links" aria-label={i18n.mainNavigation}>
            <a href={siteHref('/categories/')} aria-current={navCurrent('/categories') ? 'page' : undefined}>{i18n.navCategories}</a>
            <a href={siteHref('/archive/')} aria-current={navCurrent('/archive') ? 'page' : undefined}>{i18n.navArchive}</a>
            <a href={siteHref('/tags/')} aria-current={navCurrent('/tags') ? 'page' : undefined}>{i18n.navTags}</a>
          </nav>
        </details>
      </div>
    </header>

    <main id="main-content">
      <div class="main-layout">
        <div class="content-area">
          {hiddenPageTitle && (
            <div class="page-header">
              <h1 class="visually-hidden">{title}</h1>
            </div>
          )}
          <slot />
        </div>
        <slot name="toc" />
      </div>
    </main>

    <footer>
      <div class="footer-content">
        <div class="footer-left">
          <span class="copyright-info">&copy; {year} {site.author}.</span>
          <nav class="footer-nav" aria-label={i18n.siteInfo}>
            <a href={siteHref('/about/')}>{i18n.navAbout}</a>
            <a href={siteHref('/privacy-policy/')}>{i18n.privacyPolicy}</a>
          </nav>
        </div>
        <div class="footer-right">
          <a href={siteHref('/feed/')}>{i18n.rssSubscribe}</a>
          <a href="#main-content" class="back-to-top">{i18n.backToTop}</a>
        </div>
      </div>
    </footer>
    <Analytics />
  </body>
</html>
