---
import BaseLayout from '../layouts/BaseLayout.astro';
import { absoluteUrl } from '../utils/paths';
---

<BaseLayout title="Search" pageId="search" canonicalUrl={absoluteUrl('/search/')} noindex>
  <div class="page-header">
    <h1>Search</h1>
  </div>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="search" class="search-area"></div>
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    // PagefindUI ships under /pagefind/, generated by `astro build` + pagefind
    // indexing (see the build script in package.json). During `npm run dev` the
    // script 404s and search is unavailable locally — that is expected.
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          translations: {
            placeholder: 'Type a search term',
            zero_results: 'No results for "[SEARCH_TERM]"',
          },
        });
      }
    });
  </script>
</BaseLayout>
