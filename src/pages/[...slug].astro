---
import BaseLayout from '../layouts/BaseLayout.astro';
import Copyright from '../components/Copyright.astro';
import TocNav from '../components/TocNav.astro';
import { site } from '../site.config';
import { t } from '../i18n';
import { absoluteUrl } from '../utils/paths';
import {
  formatDate,
  getAdjacentPosts,
  getBlogPosts,
  isUpdated,
  postSlug,
  postUrl,
  tagUrl,
  type Post,
} from '../utils/posts';
import { articleJsonLd } from '../utils/jsonLd';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const allBlogPosts = await getBlogPosts();
  return allBlogPosts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post, allBlogPosts },
  }));
}

interface Props {
  post: Post;
  allBlogPosts: Post[];
}

const { post, allBlogPosts } = Astro.props;
const { Content, headings } = await render(post);
const { prev, next } = getAdjacentPosts(allBlogPosts, post);
const i18n = t(site.language);
const canonicalUrl = absoluteUrl(`/${postSlug(post)}/`);
const dateIso = post.data.date.toISOString().split('T')[0];
const articlePublishedIso = post.data.date.toISOString();
const articleModifiedIso = (post.data.updatedAt ?? post.data.date).toISOString();
const updated = isUpdated(post);
const updatedIso = articleModifiedIso.split('T')[0];
const updatedStr = formatDate(post.data.updatedAt ?? post.data.date, site.language);
const tocHeadings = headings.map((h) => ({
  depth: h.depth,
  slug: h.slug,
  text: h.text,
}));
const hasToc = tocHeadings.some((h) => h.depth >= 1 && h.depth <= 4);
const hasMermaid = (post.body ?? '').includes('```mermaid');
---

<BaseLayout
  title={post.data.title}
  description={post.data.summary}
  pageId="post"
  htmlLang={post.data.lang}
  canonicalUrl={canonicalUrl}
  articlePublishedTime={articlePublishedIso}
  articleModifiedTime={articleModifiedIso}
  jsonLd={articleJsonLd(post, canonicalUrl)}
  markdownUrl={absoluteUrl(`/${postSlug(post)}.md`)}
>
  <article class="post-article" data-pagefind-body itemscope itemtype="https://schema.org/Article">
    <link itemprop="mainEntityOfPage" href={canonicalUrl} />
    <meta itemprop="description" content={post.data.summary ?? site.description} />
    <meta itemprop="author" content={site.author} />
    <meta itemprop="publisher" content={site.title} />

    <div class="page-header">
      <h1 itemprop="headline">{post.data.title}</h1>
      <div class="post-meta">
        <div class="meta-container">
          <time class="meta-date" datetime={dateIso} itemprop="datePublished">
            {formatDate(post.data.date, site.language)}
          </time>
          {updated ? (
            <span class="meta-updated">
              <span class="updated-badge">{i18n.updatedBadge}</span>
              <time class="meta-date" datetime={updatedIso} itemprop="dateModified">{updatedStr}</time>
            </span>
          ) : (
            <meta itemprop="dateModified" content={dateIso} />
          )}
          {post.data.tags.length > 0 && (
            <div class="meta-tags">
              <ul class="tags-list">
                {post.data.tags.map((tag) => (
                  <li>
                    <a href={tagUrl(tag)} class="tag-badge">{tag}</a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      {hasToc && (
        <details class="mobile-toc">
          <summary>{i18n.toc}</summary>
          <nav class="mobile-toc-content" aria-label={i18n.toc}>
            <TocNav headings={tocHeadings} />
          </nav>
        </details>
      )}
    </div>

    <div class="post-content" itemprop="articleBody">
      <Content />
    </div>

    <Copyright postTitle={post.data.title} canonicalUrl={canonicalUrl} />

    {(prev || next) && (
      <nav class="post-navigation">
        {prev ? (
          <a href={postUrl(prev)} class="nav-link nav-prev">
            <small>← {i18n.prevPost}</small>
            <h3>{prev.data.title}</h3>
          </a>
        ) : (
          <div class="nav-link-placeholder" />
        )}
        {next ? (
          <a href={postUrl(next)} class="nav-link nav-next">
            <small>{i18n.nextPost} →</small>
            <h3>{next.data.title}</h3>
          </a>
        ) : (
          <div class="nav-link-placeholder" />
        )}
      </nav>
    )}
  </article>

  {hasMermaid && (
    <script is:inline>
      import('https://cdn.jsdelivr.net/npm/mermaid@11.4.1/dist/mermaid.esm.min.mjs').then(async ({ default: mermaid }) => {
        const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        mermaid.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'default', securityLevel: 'loose' });
        // render() per block with a unique id — passing several nodes to one
        // mermaid.run() renders only the first and silently stops.
        const pres = document.querySelectorAll('pre.mermaid');
        for (let i = 0; i < pres.length; i++) {
          try {
            const { svg } = await mermaid.render('mmd-' + i + '-' + Date.now(), pres[i].textContent);
            pres[i].innerHTML = svg;
          } catch (e) {
            console.error('[mermaid]', e);
          }
        }
      });
    </script>
  )}

  {hasToc && (
    <nav slot="toc" class="toc-area" aria-label={i18n.toc}>
      <h3>{i18n.toc}</h3>
      <TocNav headings={tocHeadings} />
    </nav>
  )}
</BaseLayout>
