---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
import { absoluteUrl } from '../utils/paths';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'privacy-policy');
if (!entry) throw new Error('Missing src/content/pages/privacy-policy.md');
const { Content } = await render(entry);
const canonicalUrl = absoluteUrl('/privacy-policy/');
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary ?? site.description}
  pageId="privacy-policy"
  canonicalUrl={canonicalUrl}
>
  <div class="page-header">
    <h1>{entry.data.title}</h1>
  </div>
  <div class="post-content">
    <Content />
  </div>
</BaseLayout>
